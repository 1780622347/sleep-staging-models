{
  "data": {
    "ppg_file": "./dreamt_processed/dreamt_ppg_with_labels.h5",
    "ecg_file": "./dreamt_processed/dreamt_ecg.h5",
    "index_file": "./dreamt_processed/dreamt_subject_index.h5",
    "batch_size": 2,
    "num_workers": 4
  },
  "training": {
    "num_epochs": 50,
    "learning_rate": 0.0001,
    "weight_decay": 1e-05,
    "patience": 10,
    "use_sleepppg_test_set": false,
    "num_runs": 1
  },
  "model": {
    "ppg_only": {
      "enabled": true
    },
    "real_ecg": {
      "enabled": true,
      "fusion_strategy": "attention"
    },
    "generated_ecg": {
      "enabled": false
    }
  },
  "output": {
    "save_dir": "./outputs_dreamt",
    "save_frequency": 5,
    "save_intermediate": true
  },
  "gpu": {
    "device_id": 0,
    "mixed_precision": false
  },
  "model_type": "ppg_only"
}