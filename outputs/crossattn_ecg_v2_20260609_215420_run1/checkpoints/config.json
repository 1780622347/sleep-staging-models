{
  "model": {
    "ppg_only": {
      "enabled": false
    },
    "ppg_with_noise": {
      "enabled": true
    },
    "real_ecg": {
      "enabled": false,
      "fusion_strategy": "attention"
    }
  },
  "model_type": "ppg_with_noise",
  "noise_config": {
    "noise_level": 0.1,
    "drift_amplitude": 0.1,
    "drift_frequency": 0.1,
    "spike_probability": 0.01,
    "spike_amplitude": 0.5
  },
  "data": {
    "ppg_file": "./dreamt_processed/dreamt_ppg_with_labels.h5",
    "ecg_file": "./dreamt_processed/dreamt_ecg.h5",
    "index_file": "./dreamt_processed/dreamt_subject_index.h5",
    "batch_size": 2,
    "num_workers": 4
  },
  "training": {
    "batch_size": 2,
    "num_epochs": 50,
    "learning_rate": 0.0001,
    "weight_decay": 1e-05,
    "patience": 15,
    "num_runs": 5,
    "use_sleepppg_test_set": true
  },
  "gpu": {
    "device_id": 0
  },
  "output": {
    "save_dir": "./outputs",
    "save_frequency": 5,
    "save_intermediate": true
  }
}